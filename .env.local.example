# ───────────────────────────────────────────────────────────────────────────
# Suuplai — variables de entorno
# 1) Copia este archivo a ".env.local"  (sin el .example)
# 2) Llena los valores
# 3) En Vercel: Settings → Environment Variables → pega los mismos
# ───────────────────────────────────────────────────────────────────────────

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_secreta

# Resend → para enviar el email de aviso por cada registro (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
NOTIFY_EMAIL=hola@suups.com.mx

# Contraseña para entrar al panel /admin (invéntala tú)
ADMIN_PASSWORD=cambia-esto-por-algo-seguro
