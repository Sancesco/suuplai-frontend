# ───────────────────────────────────────────────────────────────────────────
# Suuplai — variables de entorno
# 1) Copia este archivo a ".env.local"  (sin el .example)
# 2) Llena los valores
# 3) En Vercel: Settings → Environment Variables → pega los mismos
# ───────────────────────────────────────────────────────────────────────────

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_secreta

# Resend → para enviar el email de aviso por cada registro (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
NOTIFY_EMAIL=hola@suups.com.mx
# Remitente. Hasta verificar el dominio en Resend, déjalo en onboarding@resend.dev.
# Ya verificado suups.com.mx → MAIL_FROM="Suuplai <hola@suups.com.mx>"
MAIL_FROM=Suuplai <onboarding@resend.dev>

# Contraseña para entrar al panel /admin (invéntala tú)
ADMIN_PASSWORD=cambia-esto-por-algo-seguro

# Stripe Payment Link para el Agente Comercial ($3,480 = $3,000 + 16% IVA).
# Si se deja VACÍO, el botón "Arrancar ahora" manda a reservar demo (no se pierde el prospecto).
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# Telegram — alertas cuando alguien abre un link /r/:slug
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Tu(s) IP(s) pública(s) para NO auto-notificarte ni contarte como clic (separa varias con coma)
MY_IP=
